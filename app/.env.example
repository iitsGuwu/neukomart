# NEUKO Market — configuration
#
# ── Frontend (VITE_*, bundled into the client, safe to be public) ────────────
#
# RPC endpoint. Use a DAS-enabled RPC (e.g. Helius) for live holdings/listings.
# NOTE: VITE_ vars are visible client-side — domain-lock the key in Helius.
VITE_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_NETWORK=mainnet-beta

# Populate the marketplace with the demo layer over real NFTs (true|false).
# Defaults to false — the app runs on live data (on-chain indexer > Magic Eden).
# Set true only to repopulate the demo layer for local review.
VITE_DEMO=false

# Optional: a persistent Address Lookup Table holding the static program
# accounts, so large multi-asset swaps fit under the transaction size limit.
# Create it once via the in-app helper (createStaticLookupTable) and paste here.
VITE_LOOKUP_TABLE=

# ── Serverless / indexer (server-side only, NOT exposed to the client) ───────
#
# Upstash Redis (the Vercel KV / Upstash integration sets these automatically).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional shared secret to authenticate the Helius webhook (set the same value
# as the webhook's Authorization header in the Helius dashboard).
HELIUS_WEBHOOK_SECRET=
